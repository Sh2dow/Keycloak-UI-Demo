{
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/myrealm"
  },
  "AuthService": {
    "BaseUrl": "http://localhost:5001"
  },
  "DownstreamServices": {
    "UsersBaseUrl": "http://localhost:5005",
    "TasksBaseUrl": "http://localhost:5002",
    "OrdersBaseUrl": "http://localhost:5003",
    "PaymentsBaseUrl": "http://localhost:5004"
  },
  "RabbitMq": {
    "Uri": "amqp://guest:guest@localhost:5672"
  },
  "Payments": {
    "AutoAuthorize": true,
    "StubDelayMilliseconds": 250
  },
  "OrderExecution": {
    "AutoComplete": true,
    "StubDelayMilliseconds": 250
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
